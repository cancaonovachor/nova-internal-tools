# ==== 共通 ====
# Notion subscription の verification token（初回 webhook 受信時にログから拾う）
NOTION_VERIFICATION_TOKEN=

# Notion integration の Internal Integration Token（worker が Notion API を叩くため）
NOTION_API_KEY=

# ==== ingress ====
# enqueue する Notion イベントの allowlist（カンマ区切り）
NOTION_ALLOWED_EVENTS=page.created,page.content_updated,page.properties_updated,page.deleted,comment.created

# ローカル開発時: HTTPDirectEnqueuer で叩く worker の URL
WORKER_URL=http://localhost:8081/tasks/notion-event

# 以下 3 つを設定すると CloudTasksEnqueuer になる（本番 Cloud Run 用）
# CLOUD_TASKS_QUEUE=notion-discord-bot-events
# CLOUD_TASKS_LOCATION=asia-northeast1
# GOOGLE_CLOUD_PROJECT=your-project-id
# WORKER_INVOKER_SA=notion-bot-ingress@your-project-id.iam.gserviceaccount.com

# ==== worker ====
# DISCORD_WEBHOOK_URL を設定すると Discord に実送信する。未設定なら FileDiscordSender
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_OUTPUT_PATH=discord.txt

# page.deleted のみ追加で送信する Discord webhook URL（設定時のみ有効）
# DISCORD_DELETION_WEBHOOK_URL=https://discord.com/api/webhooks/zzz/qqq
