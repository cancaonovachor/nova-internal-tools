# Phase 1 は受信してログに書き出すだけなので、最低限この2つでOK。
# 初回サブスクライブ時に Notion が送ってくる verification_token をここに貼る。
# 未設定のときは署名検証をスキップする（ローカル確認用）。
NOTION_VERIFICATION_TOKEN=

# 生の受信イベントを JSON 1行ずつ追記するログファイル
EVENT_LOG_PATH=log.txt

# Discord 送信のスタブ出力先（Phase 1 はファイルに整形済みメッセージを追記）
DISCORD_OUTPUT_PATH=discord.txt

NOTION_API_KEY=
